pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        SCANNER_HOME = tool 'SonarScanner'

        SONARQUBE_SERVER = 'SonarQube-trivy-token'
        SONAR_PROJECT_KEY = 'task12-nodeapi-microservice'
        SONAR_PROJECT_NAME = 'Task 12 NodeAPI Microservice'

        APP_DIR = 'NodeAPI'

        IMAGE_NAME = 'task12-nodeapi'
        IMAGE_TAG = "${BUILD_NUMBER}"
        CONTAINER_NAME = 'task12-nodeapi-container'

        APP_PORT = '8000'
        CONTAINER_PORT = '3000'
    }

    stages {
        stage('Clone from GitHub') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Dapravith/Task12-DevSecOps-Jenkins-SonarQube-Docker-Trivy.git'
            }
        }

        stage('Check Runtime') {
            steps {
                sh '''
                    echo "========== Check Runtime =========="

                    echo "Node.js version:"
                    node -v

                    echo "npm version:"
                    npm -v

                    echo "Docker version:"
                    docker --version

                    echo "Docker permission test:"
                    docker ps
                '''
            }
        }

        stage('Check Project Structure') {
            steps {
                sh '''
                    echo "========== Workspace =========="
                    pwd
                    ls -la

                    echo "========== NodeAPI Folder =========="
                    ls -la $APP_DIR

                    echo "========== Check Required Files =========="
                    test -f $APP_DIR/package.json
                    test -f $APP_DIR/Dockerfile
                    test -d $APP_DIR/src

                    echo "Project structure is valid."
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        echo "========== Install Dependencies =========="
                        npm ci --no-audit --fund=false
                    '''
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${APP_DIR}") {
                    withSonarQubeEnv("${SONARQUBE_SERVER}") {
                        sh '''
                            echo "========== SonarQube Analysis =========="

                            $SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectKey="$SONAR_PROJECT_KEY" \
                            -Dsonar.projectName="$SONAR_PROJECT_NAME" \
                            -Dsonar.sources=src \
                            -Dsonar.exclusions=node_modules/**,coverage/**,dist/**,.git/**,test/** \
                            -Dsonar.scm.disabled=true
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy File Scan') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        echo "========== Trivy File Scan =========="

                        docker run --rm \
                        -v "$PWD:/project" \
                        -v "$HOME/.cache/trivy:/root/.cache/" \
                        aquasec/trivy:latest fs \
                        --scanners vuln,secret,misconfig \
                        --severity LOW,MEDIUM,HIGH,CRITICAL \
                        --skip-dirs /project/node_modules \
                        --format table \
                        /project
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        echo "========== Build Docker Image =========="

                        docker build \
                        -t $IMAGE_NAME:$IMAGE_TAG \
                        -t $IMAGE_NAME:latest \
                        .
                    '''
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    echo "========== Trivy Image Scan =========="

                    docker run --rm \
                    -v /var/run/docker.sock:/var/run/docker.sock \
                    -v "$HOME/.cache/trivy:/root/.cache/" \
                    aquasec/trivy:latest image \
                    --severity LOW,MEDIUM,HIGH,CRITICAL \
                    --format table \
                    $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                    echo "========== Run Docker Container =========="

                    docker stop $CONTAINER_NAME || true
                    docker rm $CONTAINER_NAME || true

                    docker run -d \
                    --name $CONTAINER_NAME \
                    -p $APP_PORT:$CONTAINER_PORT \
                    -e NODE_ENV=production \
                    $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    echo "========== Health Check =========="

                    sleep 5

                    curl -f http://localhost:$APP_PORT/health
                '''
            }
        }

        stage('Check Running Containers') {
            steps {
                sh '''
                    echo "========== Docker Containers =========="
                    docker ps
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
            echo "API is running on: http://JENKINS_PUBLIC_IP:${APP_PORT}/health"
        }

        failure {
            echo 'Pipeline failed. Please check the Jenkins console output.'
        }

        aborted {
            echo 'Pipeline was aborted or timeout occurred.'
        }
    }
}